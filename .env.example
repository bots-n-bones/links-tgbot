# Telegram
BOT_TOKEN=
ALLOWED_USER_IDS=123456,789012
ADMIN_USER_ID=
RUN_MODE=polling
TELEGRAM_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_MINI=gpt-4o-mini
OPENAI_MODEL_REPORT=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/linkcollector
REDIS_URL=redis://redis:6379/0

# App
DASHBOARD_URL=https://links.example.com
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=

# Schedule
BATCH_CRON_HOURS=8,20
COLLECTION_CRON_DAY=mon
COLLECTION_CRON_HOUR=9

# Channel Parser + Voice DNA (see TZ_CHANNELS.md)
CHANNEL_PARSE_MAX_POSTS=200
CHANNEL_SCRAPE_DELAY_SEC=1.5
VOICE_DNA_REPORT_LANGUAGE=ru

# Env
ENV=dev
